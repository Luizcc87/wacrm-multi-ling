# ============================================================
# wacrm-multi-ling — environment variables example
#
# Copy this file to .env.local and fill in the values.
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Meta / WhatsApp Cloud API (required for WhatsApp features)
WHATSAPP_VERIFY_TOKEN=<your-verify-token>
WHATSAPP_APP_SECRET=<your-app-secret>
ENCRYPTION_KEY=<64-hex-chars>
META_APP_SECRET=<meta-app-secret>
# Optional: true for local/CI template testing without calling Meta.
# WHATSAPP_TEMPLATES_DRY_RUN=true

# Public URLs
# NEXT_PUBLIC_APP_URL is used by /privacy, /terms and /acceptable-use canonical links.
# NEXT_PUBLIC_SITE_URL is used when generated links cannot derive the origin from a request.
NEXT_PUBLIC_APP_URL=https://crm.example.com
NEXT_PUBLIC_SITE_URL=https://crm.example.com

# Public signup control
# Set both variables to false to make the app invite-only.
# ALLOW_PUBLIC_SIGNUP=false
# NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false

# Invitation / cron security
# ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com
# AUTOMATION_CRON_SECRET=<long-random-string>

# Legal identity (public; required for Meta Tech Provider review + LGPD)
NEXT_PUBLIC_LEGAL_COMPANY_NAME=<product-name>
NEXT_PUBLIC_LEGAL_COMPANY_LEGAL_NAME=<legal-company-name>
NEXT_PUBLIC_LEGAL_CNPJ=<cnpj>
NEXT_PUBLIC_LEGAL_EMAIL=<privacy-email>
NEXT_PUBLIC_LEGAL_ABUSE_EMAIL=<abuse-email>
NEXT_PUBLIC_LEGAL_ADDRESS=<legal-address>
NEXT_PUBLIC_LEGAL_DPO_NAME=<dpo-name>
NEXT_PUBLIC_LEGAL_CITY=<city>

# White-label / Branding global (fallback when an account has not configured its own branding)
# These env vars are used as a second-priority fallback between the DB row and the built-in defaults.
# All values are optional — omit to use the built-in WaCRM defaults.
# NEXT_PUBLIC_APP_NAME=WaCRM
# NEXT_PUBLIC_APP_LOGO_URL=
# NEXT_PUBLIC_APP_FAVICON_URL=
# NEXT_PUBLIC_APP_PRIMARY_COLOR=
# NEXT_PUBLIC_SIDEBAR_COLOR=
