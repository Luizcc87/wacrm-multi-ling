# --- Application Config ---
WEB_PORT=80
APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Database Config ---
# Option 1: Supabase Cloud (Use your remote connection pool URL)
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Option 2: Localhost with Supabase (If running Supabase Docker locally)
# DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# Option 3: Local Postgres Container (The 'db' service in docker-compose.yml)
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgres://postgres:your_secure_password_here@db:5432/postgres

# --- WhatsApp / Meta ---
# Required in production. ENCRYPTION_KEY must be 64 hex chars.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_char_key
META_APP_SECRET=your_meta_app_secret
# Optional: only needed for future/resumable upload flows.
# META_APP_ID=your_meta_app_id
# Optional: true for local/CI template testing without calling Meta.
# WHATSAPP_TEMPLATES_DRY_RUN=true

# --- Public signup control ---
# Set both variables to 'false' to disable public signup and make the app invite-only.
# Leave them unset or set to any other value to keep public signup enabled.
# ALLOW_PUBLIC_SIGNUP=false
# NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false

# --- Invitation / cron security ---
# Optional allow-list for generated invite links. Comma-separated hostnames, no scheme.
# ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com
# Required if using automation Wait steps or flow timeout sweeps.
# AUTOMATION_CRON_SECRET=generate_a_long_random_string

# --- Legal identity (public; required for Meta Tech Provider review + LGPD) ---
NEXT_PUBLIC_LEGAL_COMPANY_NAME=Your Product Name
NEXT_PUBLIC_LEGAL_COMPANY_LEGAL_NAME=Your Legal Company Name Ltda
NEXT_PUBLIC_LEGAL_CNPJ=00.000.000/0000-00
NEXT_PUBLIC_LEGAL_EMAIL=privacy@example.com
NEXT_PUBLIC_LEGAL_ABUSE_EMAIL=abuse@example.com
NEXT_PUBLIC_LEGAL_ADDRESS=Street, Number, City, State, ZIP, Brazil
NEXT_PUBLIC_LEGAL_DPO_NAME=Data Protection Officer Name
NEXT_PUBLIC_LEGAL_CITY=City

# --- White-label / branding fallback (optional) ---
# Account-level branding in Settings has priority over these values.
# NEXT_PUBLIC_APP_NAME=WaCRM
# NEXT_PUBLIC_APP_LOGO_URL=https://yourdomain.com/logo.png
# NEXT_PUBLIC_APP_FAVICON_URL=https://yourdomain.com/favicon.ico
# NEXT_PUBLIC_APP_PRIMARY_COLOR=#7c3aed
# NEXT_PUBLIC_SIDEBAR_COLOR=#020617
